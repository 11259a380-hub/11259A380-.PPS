#include <stdio.h>

int main() {
    double n1, n2, n3;

    printf("Enter three numbers: ");
    scanf("%lf %lf %lf", &n1, &n2, &n3);

    // Decision making statements to find the largest
    if (n1 >= n2 && n1 >= n3)
        printf("%.2f is the largest number.", n1);

    else if (n2 >= n1 && n2 >= n3)
        printf("%.2f is the largest number.", n2);

    else
        printf("%.2f is the largest number.", n3);

    return 0;
}


