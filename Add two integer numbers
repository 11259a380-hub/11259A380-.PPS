#include <stdio.h>

int main() {
    int num1, num2, sum;

    // Ask the user for input
    printf("Enter two integers: ");
    
    // Read the two integers using scanf
    // %d is the format specifier for signed decimal integers
    scanf("%d %d", &num1, &num2);

    // Calculate the sum
    sum = num1 + num2;

    // Display the result
    printf("%d + %d = %d\n", num1, num2, sum);

    return 0;
}                                                                                                    


