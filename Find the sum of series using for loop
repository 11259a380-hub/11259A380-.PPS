#include <stdio.h>

int main() {
    int n, i, sum = 0;

    // Prompt user for input
    printf("Enter a positive integer: ");
    scanf("%d", &n);

    // For loop to iterate through numbers 1 to n
    for (i = 1; i <= n; ++i) {
        sum += i; // Add current value of i to sum
    }

    // Output the result
    printf("Sum of first %d natural numbers = %d\n", n, sum);

    return 0;
}

OUTPUT:

