#include <stdio.h>

// 1. Define the structure
struct Student {
    int rollNo;
    char name[50];
    float marks;
};

int main() {
    // 2. Declare an array of structures (size 3)
    struct Student st[3];
    int i;

    // 3. Take user input using a loop
    printf("Enter details for 3 students:\n");
    for(i = 0; i < 3; i++) {
        printf("\nStudent %d\n", i + 1);
        printf("Enter Roll No: ");
        scanf("%d", &st[i].rollNo);
        printf("Enter Name: ");
        scanf("%s", st[i].name);
        printf("Enter Marks: ");
        scanf("%f", &st[i].marks);
    }

    // 4. Display the records using a loop
    printf("\n--- Student Information List ---\n");
    for(i = 0; i < 3; i++) {
        printf("Roll No: %d, Name: %s, Marks: %.2f\n", 
                st[i].rollNo, st[i].name, st[i].marks);
    }

    return 0;
}

