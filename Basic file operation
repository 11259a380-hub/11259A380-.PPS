#include <stdio.h>
#include <stdlib.h>

int main() {
    FILE *fptr;
    char buffer[100];

    // 1. Open for writing
    fptr = fopen("example.txt", "w");
    if (fptr == NULL) {
        perror("Error opening file");
        return 1;
    }
    fprintf(fptr, "Hello, C File Handling!");
    fclose(fptr);

    // 2. Open for reading
    fptr = fopen("example.txt", "r");
    if (fptr == NULL) {
        perror("Error opening file");
        return 1;
    }
    while (fgets(buffer, 100, fptr) != NULL) {
        printf("Data from file: %s\n", buffer);
    }
    fclose(fptr);

    return 0;
}

OUTPUT :
Data from file: Hello, C File Handling!


