#include <stdio.h>
#include <math.h> // Required for log() and pow()

int main() {
    double x = 2.0, y = 3.0, z = 4.0;
    double result;

    // Evaluate log(x^3 + y^3 + z^3)
    result = log(pow(x, 3) + pow(y, 3) + pow(z, 3));

    printf("Values: x=%.1f, y=%.1f, z=%.1f\n", x, y, z);
    printf("log(x^3 + y^3 + z^3) = %lf\n", result);

    return 0;
}


OUTPUT :


Values: x=2.0, y=3.0, z=4.0
log(x^3 + y^3 + z^3) = 4.574711
