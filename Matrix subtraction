#include <stdio.h>

int main() {
    int rows, cols, i, j;
    int A[10][10], B[10][10], result[10][10];

    printf("Enter number of rows and columns: ");
    scanf("%d %d", &rows, &cols);

    // Input for Matrix A
    printf("Enter elements of Matrix A:\n");
    for (i = 0; i < rows; i++) {
        for (j = 0; j < cols; j++) {
            scanf("%d", &A[i][j]);
        }
    }

    // Input for Matrix B
    printf("Enter elements of Matrix B:\n");
    for (i = 0; i < rows; i++) {
        for (j = 0; j < cols; j++) {
            scanf("%d", &B[i][j]);
        }
    }

    // Subtracting B from A
    for (i = 0; i < rows; i++) {
        for (j = 0; j < cols; j++) {
            result[i][j] = A[i][j] - B[i][j];
        }
    }

    // Displaying the result
    printf("\nResultant Matrix (A - B):\n");
    for (i = 0; i < rows; i++) {
        for (j = 0; j < cols; j++) {
            printf("%d ", result[i][j]);
        }
        printf("\n");
    }

    return 0;
}

